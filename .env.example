# Copie para .env (não commitar) e ajuste os valores.

# Postgres (Docker)
POSTGRES_DB=questhub_dev
POSTGRES_USER=questhub
POSTGRES_PASSWORD=questhub_change_me
DATABASE_URL=postgresql://questhub:questhub_change_me@localhost:5434/questhub_dev?schema=public

# API
NODE_ENV=development
JWT_SECRET=dev_secret_change_me
WEB_ORIGIN=http://localhost:5173
DEV_USER_EMAIL=dev@questhub.local
DEV_USER_PASSWORD=dev
PORT=3001

# Firebase Admin SDK (copie para .env.development ou .env.production; nao commitar secrets)
FIREBASE_PROJECT_ID=questhub-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=questhub-dev.appspot.com
ASSET_MAX_UPLOAD_BYTES=10485760
ASSET_USER_STORAGE_LIMIT_BYTES=104857600
ASSET_IMAGE_MAX_WIDTH=2048
ASSET_IMAGE_QUALITY=82

# Web (Vite)
VITE_API_URL=http://localhost:3001
VITE_ASSET_MAX_UPLOAD_BYTES=10485760
