generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CampaignJoinPolicy {
  PUBLIC
  PRIVATE
}

enum GameSystem {
  DND_5E
  PATHFINDER_2E
}

enum CampaignCharacterStatus {
  PENDING
  ACTIVE
  REJECTED
  LEFT
  DEAD
}

enum CampaignCharacterRole {
  MASTER
  PLAYER
  NPC
}

enum CampaignSceneGridShape {
  SQUARE
  HEX
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  characters       Character[]
  createdCampaigns Campaign[]          @relation("CreatedCampaigns")
  campaignLinks    CampaignCharacter[]
  chatMessages     ChatMessage[]
  assets           Asset[]
  campaignDiaries  CampaignDiary[]
}

model Campaign {
  id          String             @id @default(cuid())
  title       String
  description String?
  inviteCode  String             @unique
  system      GameSystem
  joinPolicy  CampaignJoinPolicy @default(PUBLIC)

  createdByUserId String
  createdByUser   User   @relation("CreatedCampaigns", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters     CampaignCharacter[]
  chatMessages   ChatMessage[]
  assets         CampaignAsset[]
  scenes         CampaignScene[]
  sceneViewState CampaignSceneViewState?
  diaries        CampaignDiary[]
}

model Character {
  id        String      @id @default(cuid())
  userId    String
  name      String
  avatarUrl String?
  system    GameSystem?
  sheet     Json?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  campaigns    CampaignCharacter[]
  chatMessages ChatMessage[]
  sceneTokens  CampaignSceneToken[]

  @@index([userId])
  @@index([deletedAt])
}

model CampaignCharacter {
  id          String                  @id @default(cuid())
  campaignId  String
  characterId String                  @unique
  userId      String
  role        CampaignCharacterRole
  status      CampaignCharacterStatus @default(PENDING)
  joinedAt    DateTime?
  leftAt      DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id])
  character Character @relation(fields: [characterId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([role])
}

model ChatMessage {
  id          String   @id @default(cuid())
  campaignId  String
  characterId String
  userId      String
  content     String
  createdAt   DateTime @default(now())

  campaign  Campaign  @relation(fields: [campaignId], references: [id])
  character Character @relation(fields: [characterId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([campaignId, createdAt])
  @@index([characterId])
  @@index([userId])
}

model Asset {
  id           String   @id @default(cuid())
  userId       String
  storagePath  String   @unique
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  campaignAssets CampaignAsset[]
  campaignScenes CampaignScene[]

  @@index([userId])
}

model CampaignAsset {
  id         String   @id @default(cuid())
  campaignId String
  assetId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([campaignId, assetId])
  @@index([campaignId])
  @@index([assetId])
}

model CampaignScene {
  id                     String                 @id @default(cuid())
  campaignId             String
  name                   String
  order                  Int
  assetId                String?
  backgroundUrl          String?
  backgroundCacheKey     String?
  gridVisible            Boolean                @default(true)
  gridShape              CampaignSceneGridShape @default(SQUARE)
  gridSize               Int                    @default(32)
  metersPerCell          Float                  @default(1)
  squareMeasurementColor String                 @default("#facc15")
  hexMeasurementColor    String                 @default("#38bdf8")
  gridLineWidth          Int                    @default(1)
  gridColor              String                 @default("#ffffff")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  campaign            Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  asset               Asset?                   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  tokens              CampaignSceneToken[]
  activeForViewStates CampaignSceneViewState[] @relation("MasterActiveScene")
  forcedForViewStates CampaignSceneViewState[] @relation("ForcedScene")

  @@unique([campaignId, order])
  @@index([campaignId])
  @@index([assetId])
}

model CampaignSceneToken {
  id          String   @id @default(cuid())
  sceneId     String
  characterId String
  hidden      Boolean  @default(false)
  positionX   Float
  positionY   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scene     CampaignScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId])
  @@index([sceneId])
  @@index([characterId])
}

model CampaignSceneViewState {
  id                  String   @id @default(cuid())
  campaignId          String   @unique
  masterActiveSceneId String?
  forcedSceneId       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  campaign          Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  masterActiveScene CampaignScene? @relation("MasterActiveScene", fields: [masterActiveSceneId], references: [id], onDelete: SetNull)
  forcedScene       CampaignScene? @relation("ForcedScene", fields: [forcedSceneId], references: [id], onDelete: SetNull)

  @@index([masterActiveSceneId])
  @@index([forcedSceneId])
}

model CampaignDiary {
  id           String   @id @default(cuid())
  campaignId   String
  title        String
  content      String   @default("")
  createdById  String
  lastEditedBy String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([campaignId])
  @@index([createdById])
}
