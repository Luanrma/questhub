generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CampaignJoinPolicy {
  PUBLIC
  PRIVATE
}

enum CampaignMemberStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum CharacterRole {
  MASTER
  PLAYER
  NPC
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  memberships CampaignMember[]
  characters  Character[]
  gmCampaigns Campaign[] @relation("GMCampaigns")
}

model Campaign {
  id          String   @id @default(cuid())
  title       String
  description String?
  inviteCode  String   @unique
  gmName      String
  joinPolicy  CampaignJoinPolicy @default(PUBLIC)

  gmUserId String
  gmUser   User @relation("GMCampaigns", fields: [gmUserId], references: [id])

  createdAt DateTime @default(now())

  members    CampaignMember[]
  characters Character[]
}

model CampaignMember {
  id         String       @id @default(cuid())
  campaignId String
  userId     String
  status     CampaignMemberStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  decidedAt  DateTime?
  characterId String?     @unique

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  character Character? @relation("MemberCharacter", fields: [characterId], references: [id])

  @@unique([campaignId, userId])
  @@index([userId])
  @@index([campaignId])
}

model Character {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  name       String
  sheet      Json?
  active     Boolean  @default(true)
  role       CharacterRole @default(PLAYER)
  status     CampaignMemberStatus @default(ACTIVE)
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  member   CampaignMember? @relation("MemberCharacter")

  @@index([campaignId])
  @@index([userId])
}
